# =============================================================================
# Warrant — Contracts (Foundry) environment
# =============================================================================
# Source these from `contracts/.env` or your shell before running forge.
# script/Deploy.s.sol (prod) is env-driven; script/DeployLocal.s.sol uses mocks.
# Keep DEPLOYER_PRIVATE_KEY secret; never commit a real key.
# -----------------------------------------------------------------------------

# --- Deployer ----------------------------------------------------------------
# Deployer / operator key. Accepts a uint or 0x-prefixed hex.
# REQUIRED for Deploy.s.sol (DeployLocal.s.sol falls back to the anvil key).
DEPLOYER_PRIVATE_KEY=

# --- cUSD token --------------------------------------------------------------
# cUSD token address for the target network. Pass per-deploy or set here.
#   mainnet    0x765DE816845861e75A25fCA122bb6898B8B1282a
#   alfajores  0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1
# REQUIRED for Deploy.s.sol. (mainnet default below)
CUSD_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a

# --- Constructor options -----------------------------------------------------
# ERC-8004 registry address. Default address(0) => only the operator key can
# release/reject.
# OPTIONAL
REGISTRY_ADDRESS=

# Agent operator address. Defaults to the deployer address.
# OPTIONAL
AGENT_OPERATOR=

# Per-warrant verification fee in cUSD units (18 decimals).
# Default 1e16 = 0.01 cUSD.
# OPTIONAL
VERIFICATION_FEE=

# Mento Broker for multi-currency payout swaps (cUSD -> local stable on release).
# Leave unset (address(0)) to settle every payout in cUSD.
#   mainnet    0x777A8255cA72412f0d706dc03C9D1987306B4CaD
#   alfajores  0xD3Dff18E465bCa6241A244144765b4421Ac14D09
# OPTIONAL — set the mainnet Broker to enable local-currency payouts.
BROKER_ADDRESS=0x777A8255cA72412f0d706dc03C9D1987306B4CaD

# --- RPC endpoints (foundry.toml [rpc_endpoints]) ----------------------------
# Used by `--rpc-url celo` and `--rpc-url alfajores`.
#   celo       https://forno.celo.org
#   alfajores  https://alfajores-forno.celo-testnet.org
# REQUIRED for the matching network deploy.
CELO_RPC_URL=https://forno.celo.org
ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org

# --- Verification (forge verify) ---------------------------------------------
# Celoscan API key used by `forge verify-contract` / `--verify`.
# OPTIONAL (required only when verifying).
CELOSCAN_API_KEY=
