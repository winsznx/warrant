# =============================================================================
# Warrant — Agent daemon environment
# =============================================================================
# The daemon listens for ProofSubmitted events, runs the four verifiers, and
# calls agentRelease / agentReject onchain. dotenv loads this from the repo
# root `.env` — copy that file (or this one) and fill in the values below.
# Keep AGENT_PRIVATE_KEY and X402_PRIVATE_KEY secret; never commit real keys.
# -----------------------------------------------------------------------------

# --- Chain connection --------------------------------------------------------
# JSON-RPC endpoint. Mainnet by default.
#   mainnet    https://forno.celo.org
#   alfajores  https://alfajores-forno.celo-testnet.org   (testnet only)
# REQUIRED
CELO_RPC_URL=https://forno.celo.org

# Operator key authorized to call agentRelease / agentReject on the contract.
# REQUIRED — secret, leave blank in committed files.
AGENT_PRIVATE_KEY=

# Deployed WarrantAgent contract address.
# REQUIRED
WARRANT_CONTRACT_ADDRESS=

# --- Verifier LLM (receipt / delivery / manual) ------------------------------
# The agent reasons with an LLM via an OpenAI-compatible API. Set ONE of:
#   GROQ_API_KEY    -> Groq (free tier, fast). Defaults: vision
#                      meta-llama/llama-4-scout-17b-16e-instruct, text
#                      llama-3.3-70b-versatile. Get one at console.groq.com.
#   OPENAI_API_KEY  -> OpenAI (gpt-4o for both vision + text).
# Without any key, those verifiers fall back to a keyword heuristic.
# OPTIONAL (recommended for the real demo)
GROQ_API_KEY=
OPENAI_API_KEY=
# Advanced overrides (any provider):
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
# LLM_VISION_MODEL=

# GitHub token for the milestone (merged-PR) verifier. Without it the verifier
# falls back to a heuristic check. A read-only PAT on your account is enough.
# OPTIONAL
GITHUB_TOKEN=

# --- IPFS --------------------------------------------------------------------
# Gateway used to fetch proof payloads. Default shown.
# OPTIONAL
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# --- ERC-8004 identity (register.ts) -----------------------------------------
# IdentityRegistry used by `pnpm register` to mint the agent's ERC-8004 identity
# and attach its agent card. Defaults to the Celo mainnet registry when unset:
#   celo mainnet  0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
# OPTIONAL
REGISTRY_CONTRACT_ADDRESS=
# Set to an existing agentId to UPDATE its card (setAgentURI) instead of minting
# a new identity. Leave blank to mint a fresh agentId.
# OPTIONAL
AGENT_ID=
# Public endpoint + image embedded in the ERC-8004 agent card.
# OPTIONAL
AGENT_ENDPOINT=https://trywarrant.xyz
AGENT_IMAGE_URL=https://trywarrant.xyz/logo.png

# --- Event backfill ----------------------------------------------------------
# Block number to backfill ProofSubmitted events from on startup. Leave blank
# to only process new events.
# OPTIONAL
AGENT_START_BLOCK=

# --- x402 micro-fee API (optional) -------------------------------------------
# Enable the x402 paid-API client for per-verification micro-fees.
# OPTIONAL
X402_ENABLED=false
X402_ENDPOINT=
# Secret — leave blank in committed files.
X402_PRIVATE_KEY=

# --- Self Agent ID (ERC-8004 proof-of-human for the agent) -------------------
# Exported via the @selfxyz/agent-sdk CLI after a human scans their passport:
#   npx @selfxyz/agent-sdk register init --mode agent-identity \
#     --human-address 0xYourWallet --network testnet
# OPTIONAL
SELF_AGENT_PRIVATE_KEY=
