# =============================================================================
# Warrant — App (Next.js 15) environment
# =============================================================================
# Copy to `.env.local` and fill in. NEXT_PUBLIC_* values are build-time and
# exposed to the browser, so never put secrets in them. Values without the
# NEXT_PUBLIC_ prefix are server-only and stay on the Node/serverless side.
# -----------------------------------------------------------------------------

# --- Chain (public) ----------------------------------------------------------
# 42220 = Celo mainnet, 44787 = Alfajores testnet. Default: 42220 (mainnet).
# OPTIONAL (defaults to 42220 mainnet if unset)
NEXT_PUBLIC_CELO_CHAIN_ID=42220

# Deployed WarrantAgent contract address for the selected chain.
# REQUIRED for all on-chain features (lock / proof / release).
NEXT_PUBLIC_WARRANT_CONTRACT=

# --- Token (public) ----------------------------------------------------------
# Optional override for the cUSD token address. Leave blank to use the
# built-in default per chain:
#   mainnet    0x765DE816845861e75A25fCA122bb6898B8B1282a
#   alfajores  0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1
# OPTIONAL
NEXT_PUBLIC_CUSD_ADDRESS=

# --- Wallet / RPC transport (public) -----------------------------------------
# WalletConnect Cloud project id. Injected wallets and MiniPay work without it.
# OPTIONAL
NEXT_PUBLIC_WALLETCONNECT_ID=

# Override RPC transports. Leave blank to use the public Forno endpoints.
# OPTIONAL
NEXT_PUBLIC_CELO_RPC_URL=
NEXT_PUBLIC_ALFAJORES_RPC_URL=

# --- IPFS / explorers (public) -----------------------------------------------
# Gateway used to read proofs pinned to IPFS. Default shown.
# OPTIONAL
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ERC-8004 agent explorer base URL. Default shown.
# OPTIONAL
NEXT_PUBLIC_8004SCAN_URL=https://8004scan.io

# --- Self Agent identity (public) --------------------------------------------
# Self app id for agent identity verification.
# OPTIONAL
NEXT_PUBLIC_SELF_APP_ID=
# "true" makes Self verification blocking; default "false" (non-blocking).
# OPTIONAL
NEXT_PUBLIC_SELF_REQUIRED=false

# =============================================================================
# Server-only secrets — NEVER expose to the browser, never commit real values.
# =============================================================================

# Pinata JWT used by /api/proof to pin proof payloads to IPFS.
# REQUIRED for the proof upload route.
PINATA_JWT=

# HMAC secret used by /api/webhook/github to validate milestone webhooks.
# REQUIRED for the GitHub webhook route.
GITHUB_WEBHOOK_SECRET=

# --- SocialConnect (phone -> wallet, server-only) ----------------------------
# Funded issuer key with ODIS quota (cUSD approved to OdisPayments). When unset,
# /api/resolve-phone is disabled and the create flow falls back to open-claim.
# OPTIONAL
SOCIALCONNECT_ISSUER_PRIVATE_KEY=
SOCIALCONNECT_RPC_URL=https://forno.celo.org

# --- Self proof-of-human (public + claim gating) -----------------------------
# When NEXT_PUBLIC_SELF_REQUIRED=true AND an endpoint+scope are set, the claim
# flow requires a Self zero-knowledge proof-of-human. Self's testnet is Celo
# Sepolia (11142220), NOT Alfajores. The endpoint must be a public HTTPS URL
# (no localhost) — use a tunnel for local dev.
# OPTIONAL (all default-off)
NEXT_PUBLIC_SELF_APP_NAME=Warrant
NEXT_PUBLIC_SELF_SCOPE=warrant-human
NEXT_PUBLIC_SELF_ENDPOINT=
# "https" (mainnet) | "staging_https" (Celo Sepolia testnet)
NEXT_PUBLIC_SELF_ENDPOINT_TYPE=https

# --- x402 micropayments (thirdweb facilitator) -------------------------------
# When enabled, POST /api/proof charges a $0.01 cUSD x402 micropayment to the
# agent before pinning the proof — the user's wallet auto-pays the 402.
# Default-off + fail-open: never blocks the proof flow if unset/misconfigured.
# Needs a thirdweb account (secret key + a Server Wallet funded with CELO for gas).
# OPTIONAL
X402_ENABLED=                       # "true" to enforce (server)
NEXT_PUBLIC_X402_ENABLED=           # "true" to enable client auto-pay (mirror)
THIRDWEB_SECRET_KEY=                # Project Secret Key (unprefixed ~86 chars) — Project > Settings
THIRDWEB_VAULT_ACCESS_TOKEN=        # Vault Access Token (vt_act_...) — lets the server wallet sign
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=     # Public Client ID (browser auto-pay). = sha256(secretKey) first 32 hex; also shown in the dashboard
X402_SERVER_WALLET_ADDRESS=         # thirdweb Server Wallet address (fund with CELO for gas)
X402_PAY_TO=0x7273dE585311a5139Ef83f0F6Dbb29F3e57b3389  # where cUSD lands (agent operator)
X402_RESOURCE_URL=https://trywarrant.xyz/api/proof       # canonical URL clients sign over
# Advanced — cUSD's EIP-712 domain, confirmed on-chain (name "Mento Dollar",
# version "3"). Overridable here without a code change if Mento upgrades again:
# X402_PRICE_CUSD=10000000000000000
# X402_CUSD_NAME=Mento Dollar
# X402_CUSD_VERSION=3
# X402_CUSD_PRIMARY_TYPE=Permit
