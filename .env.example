# =============================================================================
# Warrant — root env pointer
# =============================================================================
# Each package has its own .env.example. Copy the one(s) you need:
#
#   app/.env.example        -> app/.env.local        (Next.js front end + API)
#   agent/.env.example      -> .env  (repo root)      (agent daemon; dotenv reads root)
#   contracts/.env.example  -> contracts/.env         (Foundry deploy)
#
# See README.md for full setup and deploy instructions.
# -----------------------------------------------------------------------------

# --- Shared values (must match across packages) ------------------------------
# RPC endpoint (mainnet by default). App uses NEXT_PUBLIC_CELO_RPC_URL;
# agent uses CELO_RPC_URL; contracts use CELO_RPC_URL.
#   mainnet    https://forno.celo.org
#   alfajores  https://alfajores-forno.celo-testnet.org   (testnet only)
CELO_RPC_URL=https://forno.celo.org

# Deployed WarrantAgent address. Keep these three in sync:
#   app       -> NEXT_PUBLIC_WARRANT_CONTRACT
#   agent     -> WARRANT_CONTRACT_ADDRESS
#   contracts -> emitted by the deploy script
WARRANT_CONTRACT_ADDRESS=
NEXT_PUBLIC_WARRANT_CONTRACT=

# Pinata JWT. Server-only: used by the app's /api/proof route to pin to IPFS.
PINATA_JWT=
